#handle line endings automatically
* text=auto

#ensure consistent line endings for specific file types
*.java text eol=lf
*.py text eol=lf
#minio initialization script
*.sh text eol=lf 
*.yaml text eol=lf
*.yml text eol=lf
*.properties text eol=lf
*.md text eol=lf
.env text eol=lf
.gitignore text eol=lf

#windows-specific files
*.cmd text eol=crlf
*.bat text eol=crlf